DJANGO_ENV=dev
DEBUG=true
SECRET_KEY=replace-with-your-secret-key
ALLOWED_HOSTS=127.0.0.1,localhost

DB_NAME=dvdrental
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432

API_PAGE_SIZE=20

JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=true
JWT_BLACKLIST_AFTER_ROTATION=true
JWT_UPDATE_LAST_LOGIN=false
JWT_ALGORITHM=HS256
# Optional: separate key for signing JWTs (defaults to SECRET_KEY if omitted)
# JWT_SIGNING_KEY=replace-with-jwt-signing-key
